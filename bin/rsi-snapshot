#!/usr/bin/env bash
set -euo pipefail
# rsi-snapshot — snapshot agent home directory
source "$(dirname "$0")/../lib/common.sh"

if [[ $# -lt 1 ]]; then
    echo "Usage: rsi snapshot <name>"
    exit 1
fi

name="$1"
validate_name "$name"
require_container "$name"

cn="$(container_name "$name")"
container_root="/var/lib/nixos-containers/${cn}"
snapshot_dir="${RSI_ROOT}/.snapshots/${name}"
timestamp="$(date +%Y%m%d-%H%M%S)"
snap_path="${snapshot_dir}/${timestamp}"

src_dir="${container_root}/home/agent"
if ! sudo test -d "$src_dir"; then
    echo "Error: agent home directory not found at ${src_dir}" >&2
    exit 1
fi

mkdir -p "$snap_path"

echo "Snapshotting agent '${name}' home directory..."
if ! sudo rsync -a --info=progress2 "${src_dir}/" "${snap_path}/"; then
    echo "Error: snapshot failed, cleaning up partial snapshot" >&2
    rm -rf "$snap_path"
    exit 1
fi

echo "Snapshot saved: ${snap_path}"
echo ""

# Show recent snapshots
echo "Snapshots for '${name}':"
ls -1t "$snapshot_dir" | head -5
