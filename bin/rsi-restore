#!/usr/bin/env bash
set -euo pipefail
# rsi-restore — restore agent home directory from snapshot
source "$(dirname "$0")/../lib/common.sh"

if [[ $# -lt 1 ]]; then
    echo "Usage: rsi restore <name> [snapshot]"
    echo ""
    echo "  If no snapshot specified, uses the most recent one."
    exit 1
fi

name="$1"
snapshot="${2:-}"
validate_name "$name"
require_container "$name"

cn="$(container_name "$name")"
container_root="/var/lib/nixos-containers/${cn}"
snapshot_dir="${RSI_ROOT}/.snapshots/${name}"

if [[ ! -d "$snapshot_dir" ]]; then
    echo "Error: no snapshots found for agent '${name}'" >&2
    exit 1
fi

if [[ -z "$snapshot" ]]; then
    snapshot="$(ls -1t "$snapshot_dir" | head -1)"
    if [[ -z "$snapshot" ]]; then
        echo "Error: no snapshots found for agent '${name}'" >&2
        exit 1
    fi
    echo "Using most recent snapshot: ${snapshot}"
fi

# Validate snapshot name to prevent path traversal (must be YYYYMMDD-HHMMSS format)
if [[ ! "$snapshot" =~ ^[0-9]{8}-[0-9]{6}$ ]]; then
    echo "Error: invalid snapshot name '${snapshot}' (expected YYYYMMDD-HHMMSS format)" >&2
    exit 1
fi

snap_path="${snapshot_dir}/${snapshot}"
if [[ ! -d "$snap_path" ]]; then
    echo "Error: snapshot '${snapshot}' not found" >&2
    echo "Available snapshots:"
    ls -1t "$snapshot_dir"
    exit 1
fi

# Warn if container is running — restoring under a live system risks corruption
if container_running "$name"; then
    echo "Warning: agent '${name}' is running. Restoring while running may cause data corruption." >&2
    echo "Consider stopping it first: rsi stop ${name}" >&2
    echo ""
    read -r -p "Continue anyway? [y/N] " confirm
    if [[ "$confirm" != [yY] ]]; then
        echo "Aborted."
        exit 1
    fi
fi

echo "Restoring agent '${name}' from snapshot '${snapshot}'..."
sudo rsync -a --delete --info=progress2 "${snap_path}/" "${container_root}/home/agent/"
sudo "$NIXOS_CONTAINER" run "$cn" -- chown -R agent:users /home/agent/ 2>/dev/null || true

echo "Restore complete."
